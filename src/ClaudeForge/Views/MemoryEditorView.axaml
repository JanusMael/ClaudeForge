<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bennewitz.Ninja.ClaudeForge.ViewModels"
             xmlns:sdk="using:Bennewitz.Ninja.ClaudeForge.Sdk.Memory"
             xmlns:loc="clr-namespace:Bennewitz.Ninja.ClaudeForge.Localization"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia.Tight"
             xmlns:mdc="clr-namespace:Markdown.Avalonia.Controls;assembly=Markdown.Avalonia"
             xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
             xmlns:ctrl="using:Bennewitz.Ninja.ClaudeForge.Controls"
             x:Class="Bennewitz.Ninja.ClaudeForge.Views.MemoryEditorView"
             x:DataType="vm:MemoryEditorViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="16">

            <!-- Code section header — matches the nav-pill styling used by other top-level
                 editor views.  HorizontalAlignment removed (was Left) so the header pill
                 fills its parent's width and the right-edge Refresh button has a stable
                 anchor; without this the pill would shrink-wrap its content and the
                 button would float on top of the title text. -->
            <Border Background="{DynamicResource NavSelectedAccentBrush}"
                    TextElement.Foreground="White"
                    CornerRadius="6"
                    Padding="14,8"
                    VerticalAlignment="Center">
                <DockPanel LastChildFill="True">
                    <!-- Refresh shared by both tabs.  Hosted in the header pill so the
                         tabs themselves no longer need their own toolbar (was wasting
                         vertical space + creating a gap above the row content).  Visible
                         only when the inventory is showing — the viewer pane has its
                         own Back-to-list affordance.  Border + Foreground are explicit
                         so it reads correctly against the accent-blue pill background. -->
                    <Button DockPanel.Dock="Right"
                            Content="{x:Static loc:Strings.ButtonRefresh}"
                            Command="{Binding RefreshCommand}"
                            IsVisible="{Binding !IsViewerVisible}"
                            Foreground="White"
                            Background="Transparent"
                            BorderBrush="White"
                            BorderThickness="1"
                            Padding="10,2"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{x:Static loc:Strings.ButtonRefresh}"
                            Margin="8,0,0,0" />
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Static loc:Strings.HeaderMemoryCode}"
                                   FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="{x:Static loc:Strings.NavDescMemory}"
                                   FontSize="11" Opacity="0.85" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Code section body — TabControl with two tabs. -->
            <TabControl IsVisible="{Binding HasCodeMemory}"
                        SelectedIndex="{Binding SelectedMemoryTabIndex, Mode=TwoWay}">

                <!-- ── Tier 1 — User Memory (read-only inventory) ────────── -->
                <TabItem Header="{x:Static loc:Strings.HeaderTabUserMemory}">
                    <Grid Margin="0,4,0,0">
                        <!-- Inventory list — visible when no file is selected.
                             Categories start COLLAPSED so the user sees the high-level
                             list first; click an Expander to drill in.  Avoids the
                             "wall of files" problem when many categories are populated. -->
                        <ItemsControl ItemsSource="{Binding Tier1Groups}"
                                      IsVisible="{Binding !IsViewerVisible}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:UserMemoryGroupViewModel">
                                    <Expander Margin="0,2" IsExpanded="False">
                                        <Expander.Header>
                                            <!-- ToolTip on the header StackPanel (not the Expander
                                                 itself) so the description triggers only on the
                                                 clickable header — not when the user is hovering
                                                 over individual file rows in the expanded body. -->
                                            <StackPanel Orientation="Horizontal" Spacing="8"
                                                        ToolTip.Tip="{Binding Tooltip}">
                                                <TextBlock Text="{Binding HumanLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CountLabel}" Opacity="0.6" />
                                            </StackPanel>
                                        </Expander.Header>
                                        <StackPanel Spacing="2" Margin="0,4">
                                            <TextBlock IsVisible="{Binding IsEmpty}"
                                                       Text="—"
                                                       Opacity="0.5"
                                                       FontStyle="Italic" />
                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="sdk:UserMemoryFile">
                                                        <Border Padding="8,4"
                                                                BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                                                BorderThickness="0,0,0,1">
                                                            <!-- Grid layout: DisplayName button (auto) | Subtitle (fills, vertically centered) | Reveal (auto).
                                                                 Replaces the prior DockPanel where the Subtitle was the LastChildFill child and
                                                                 ended up top-aligned because the DisplayName button defaulted to Dock=Top.
                                                                 Grid with VerticalAlignment="Center" on every cell keeps the Subtitle inline
                                                                 with the DisplayName button regardless of the row's measured height. -->
                                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                                  VerticalAlignment="Center">
                                                                <!-- ToolTip surfaces the file's full absolute path on hover —
                                                                     the DisplayName is a short label, so the path is the
                                                                     disambiguator (which agents/ vs project vs cross-tool file). -->
                                                                <Button Grid.Column="0"
                                                                        Content="{Binding DisplayName}"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        HorizontalContentAlignment="Left"
                                                                        FontWeight="SemiBold"
                                                                        Padding="0"
                                                                        ToolTip.Tip="{Binding AbsolutePath}"
                                                                        AutomationProperties.Name="{Binding DisplayName, StringFormat='Open memory file {0}'}"
                                                                        Command="{Binding $parent[ItemsControl;1].((vm:MemoryEditorViewModel)DataContext).LoadFileCommand}"
                                                                        CommandParameter="{Binding}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Subtitle}"
                                                                           Opacity="0.6"
                                                                           FontSize="11"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"
                                                                           Margin="8,0,0,0" />
                                                                <!-- Per-row action group: Open in editor + Reveal in Explorer.
                                                                     Open in editor delegates to IShellLauncher.OpenInDefaultEditor,
                                                                     which on Windows uses the registered file association
                                                                     (VS Code / Notepad / etc. for .md), on macOS uses `open -t`,
                                                                     and on Linux uses xdg-open. -->
                                                                <StackPanel Grid.Column="2"
                                                                            Orientation="Horizontal"
                                                                            Spacing="4"
                                                                            Margin="6,0,0,0"
                                                                            VerticalAlignment="Center">
                                                                    <Button
                                                                        Content="{x:Static loc:Strings.ButtonOpenInEditor}"
                                                                        FontSize="11"
                                                                        Padding="6,2"
                                                                        AutomationProperties.Name="{x:Static loc:Strings.ButtonOpenInEditor}"
                                                                        Command="{Binding $parent[ItemsControl;1].((vm:MemoryEditorViewModel)DataContext).OpenInEditorCommand}"
                                                                        CommandParameter="{Binding AbsolutePath}" />
                                                                    <Button
                                                                        Content="{x:Static loc:PlatformLabels.Reveal}"
                                                                        FontSize="11"
                                                                        Padding="6,2"
                                                                        AutomationProperties.Name="{x:Static loc:Strings.ButtonReveal}"
                                                                        Command="{Binding $parent[ItemsControl;1].((vm:MemoryEditorViewModel)DataContext).RevealCommand}"
                                                                        CommandParameter="{Binding AbsolutePath}" />
                                                                    <!-- Delete (red, like the Footprint tab) — shown only for
                                                                         standalone deletable files.  Hidden for cross-tool
                                                                         memory (Codex/Gemini/OpenCode), which is owned by
                                                                         another tool.  For a skill it removes the whole
                                                                         skills/<name>/ directory (confirm dialog cites the
                                                                         real folder count + size). -->
                                                                    <Button
                                                                        Content="{x:Static loc:Strings.ButtonDeleteFootprint}"
                                                                        FontSize="11"
                                                                        Padding="6,2"
                                                                        Foreground="#C62828"
                                                                        IsVisible="{Binding IsDeletable}"
                                                                        AutomationProperties.Name="{Binding DisplayName, StringFormat='Delete {0}'}"
                                                                        Command="{Binding $parent[ItemsControl;1].((vm:MemoryEditorViewModel)DataContext).DeleteUserMemoryFileCommand}"
                                                                        CommandParameter="{Binding}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- File viewer — visible when a Tier 1 file is open.  Toolbar
                             (Back-to-list + read-only note) lives INSIDE the viewer
                             border so it's tied to the viewer it controls — replaces
                             the prior page-level toolbar that wasted vertical space when
                             the viewer wasn't open. -->
                        <DockPanel IsVisible="{Binding IsViewerVisible}" LastChildFill="True">
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="4,4,0,0"
                                    Padding="8,6">
                                <DockPanel LastChildFill="True">
                                    <!-- Back-to-list moved to the far LEFT
                                         with the shared orange "back-button" Style class
                                         (same look as the deep-link Back at the bottom of
                                         the nav sidebar).  Replaces the stale "click
                                         Reveal-in-Explorer" hint label that used to live
                                         on the left — there is no Reveal button on this
                                         toolbar, so the hint pointed at a non-existent
                                         control.  Open-in-Editor is the actual edit path. -->
                                    <Button DockPanel.Dock="Left"
                                            Classes="back-button"
                                            Content="{x:Static loc:Strings.ButtonBack}"
                                            Command="{Binding CloseViewerCommand}"
                                            FontWeight="SemiBold"
                                            FontSize="11"
                                            Padding="10,4"
                                            Margin="0,0,8,0"
                                            AutomationProperties.Name="{x:Static loc:Strings.ButtonBack}"
                                            VerticalAlignment="Center" />
                                    <!-- Right-aligned action group: Open in editor + Copy markdown.
                                         Open in editor uses the registered file association
                                         (e.g., VS Code for .md on a typical Windows install) so
                                         users can edit Tier 1 markdown in their preferred external
                                         editor.  Copy markdown is the smoke-iteration aid: pushes
                                         ViewerContent onto the platform clipboard via the View's
                                         CopyMarkdownRequested handler. -->
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <!-- FallbackValue='' silences the null-traversal warning that
                                             fires once during viewer tear-down: SelectedFile flips to
                                             null and Avalonia re-evaluates this binding before the
                                             button is unrendered.  Same pattern EnvironmentEditorView
                                             uses for its SelectedEntry.* bindings. -->
                                        <Button Content="{x:Static loc:Strings.ButtonOpenInEditor}"
                                                Command="{Binding OpenInEditorCommand}"
                                                CommandParameter="{Binding SelectedFilePath}"
                                                FontSize="11"
                                                AutomationProperties.Name="{x:Static loc:Strings.ButtonOpenInEditor}"
                                                Padding="8,2" />
                                        <Button Content="{x:Static loc:Strings.ButtonCopyMarkdown}"
                                                Command="{Binding CopyMarkdownCommand}"
                                                FontSize="11"
                                                AutomationProperties.Name="{x:Static loc:Strings.ButtonCopyMarkdown}"
                                                Padding="8,2" />
                                    </StackPanel>
                                    <!-- LastChildFill takes whatever's left — we put a single empty
                                         control here so the DockPanel renders cleanly without a
                                         filler text block competing for vertical space. -->
                                    <Panel />
                                </DockPanel>
                            </Border>
                            <!-- Structured front-matter card — shown only when the open file
                                 has a YAML front-matter block (parsed by YamlFrontMatter in
                                 the VM). Renders key/value rows instead of dumping the raw
                                 block into the markdown body, matching the Agents & Skills
                                 viewer. Sits between the toolbar (top) and body (fills) with
                                 side-only borders so the three panes read as one framed box. -->
                            <Border DockPanel.Dock="Top"
                                    IsVisible="{Binding HasViewerFrontMatter}"
                                    Background="{DynamicResource AppCodeBlockBackgroundBrush}"
                                    BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                    BorderThickness="1,0,1,0"
                                    Padding="12,8">
                                <ItemsControl ItemsSource="{Binding ViewerFrontMatter}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MemoryFrontMatterRow">
                                            <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Key}"
                                                           FontWeight="SemiBold"
                                                           MinWidth="96"
                                                           Margin="0,0,12,0"
                                                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <Border BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                    BorderThickness="1,0,1,1"
                                    Padding="12"
                                    CornerRadius="0,0,4,4">
                                <!-- Rendered markdown body via the shared MarkdownBodyView control (Controls/MarkdownBodyView.axaml): the ~185-line MarkdownStyle + the dark-theme restyle tree-walk live there, shared with the Agents and Skills page. MaxHeight caps the height so it scrolls internally. -->
                                <ctrl:MarkdownBodyView Markdown="{Binding ViewerContent}" MaxHeight="600" />
                            </Border>
                        </DockPanel>
                    </Grid>
                </TabItem>

                <!-- ── Tier 2 — Footprint (audit + delete) ────────────────── -->
                <TabItem Header="{x:Static loc:Strings.HeaderTabFootprint}">
                    <!-- No per-tab toolbar — Refresh moved to the header pill.  The
                         category list flows directly under the tab header so there's
                         no dead vertical space.  Below the category table, a separate
                         Expander surfaces the per-project transcript breakdown so the
                         user can wipe one project's history without touching others
                         (finer-grained than the Session transcripts category-level delete). -->
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <!-- Warning banner — surfaces when total footprint
                             crosses the FootprintWarningThresholdBytes constant
                             (5 GiB).  Soft-amber styling (vs the destructive
                             red dialog or the accent-blue header pill) flags
                             the issue without alarming.  The body suggests
                             the user expand the per-project breakdown to
                             wipe specific projects rather than the whole
                             Session-transcripts category. -->
                        <!-- Theme-aware caution palette: AppCautionBackgroundBrush is a
                             warm amber tint defined per-theme in App.axaml so the banner
                             stays readable on dark theme (the prior #FFF3E0 hardcode was
                             white-cream and disappeared on dark backgrounds).
                             AppCautionBrush is the matching amber accent for headers /
                             borders.  Body text uses AppPrimaryTextBrush so it inherits
                             the theme's high-contrast foreground rather than the prior
                             hardcoded #5D4037 brown which read poorly on dark theme. -->
                        <Border IsVisible="{Binding IsFootprintLarge}"
                                Background="{DynamicResource AppCautionBackgroundBrush}"
                                BorderBrush="{DynamicResource AppCautionBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{x:Static loc:Strings.HeaderFootprintLargeWarning}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppCautionBrush}" />
                                <TextBlock Text="{Binding FootprintWarningMessage}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}" />
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding FootprintRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FootprintRowViewModel">
                                    <Border Padding="8,6"
                                            BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <!-- Open in editor — for category paths that resolve to
                                                 a single file (history.jsonl, bash-commands.log,
                                                 cost-tracker.log) the OS dispatches the file to its
                                                 registered editor; for category paths that resolve
                                                 to a directory (projects/, sessions/, todos/) the OS
                                                 typically falls back to the file manager.  We accept
                                                 the file/dir asymmetry to keep the per-row UX
                                                 consistent across categories. -->
                                                <Button Content="{x:Static loc:Strings.ButtonOpenInEditor}"
                                                        FontSize="11"
                                                        Padding="6,2"
                                                        AutomationProperties.Name="{Binding HumanLabel, StringFormat='Open {0} in editor'}"
                                                        Command="{Binding $parent[ItemsControl].((vm:MemoryEditorViewModel)DataContext).OpenInEditorCommand}"
                                                        CommandParameter="{Binding AbsolutePath}" />
                                                <Button Content="{x:Static loc:PlatformLabels.Reveal}"
                                                        FontSize="11"
                                                        Padding="6,2"
                                                        AutomationProperties.Name="{Binding HumanLabel, StringFormat='Reveal {0} in file manager'}"
                                                        Command="{Binding $parent[ItemsControl].((vm:MemoryEditorViewModel)DataContext).RevealCommand}"
                                                        CommandParameter="{Binding AbsolutePath}" />
                                                <Button Content="{x:Static loc:Strings.ButtonDeleteFootprint}"
                                                        FontSize="11"
                                                        Padding="6,2"
                                                        Foreground="#C62828"
                                                        AutomationProperties.Name="{Binding HumanLabel, StringFormat='Delete {0}'}"
                                                        Command="{Binding $parent[ItemsControl].((vm:MemoryEditorViewModel)DataContext).DeleteFootprintCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                            <Grid ColumnDefinitions="*,80,80,140" RowDefinitions="Auto,Auto">
                                                <!-- Tooltip on the human label so hovering the
                                                 row's title surfaces what the category
                                                 contains and how Claude uses it — useful
                                                 context before deciding whether to delete. -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding HumanLabel}"
                                                           FontWeight="SemiBold"
                                                           ToolTip.Tip="{Binding Tooltip}" />
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="{Binding AbsolutePath}"
                                                           Opacity="0.6"
                                                           FontSize="11"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontFamily="Consolas, Menlo, monospace" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                                           Text="{Binding FileCount}"
                                                           Opacity="0.8"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                                                           Text="{Binding HumanSize}"
                                                           Opacity="0.8"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <StackPanel Grid.Row="0" Grid.Column="3" Grid.RowSpan="2"
                                                            Orientation="Horizontal" Spacing="4"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="{x:Static loc:Strings.HeaderInStandardBackup}"
                                                               FontSize="11" Opacity="0.7" />
                                                    <TextBlock Text="{Binding InStandardBackupLabel}"
                                                               FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Per-project transcript breakdown.  Visible only when
                         ~/.claude/projects/ has at least one project on disk.
                         Starts collapsed — most users will only drill in when
                         they explicitly want to clean up one project's chat
                         history without nuking the rest.

                         Implemented as Button + IsVisible-bound ItemsControl
                         (toggled via a VM RelayCommand) instead of an Expander
                         or ToggleButton:
                           • Avalonia's default Expander theme indents both
                             header and body, which the user reported as
                             "indented oddly" and "wastes real estate".
                           • ToggleButton's checked/hover state visuals
                             collapsed text + background to similar values
                             on light theme — caused flicker and occasional
                             invisibility of the header text.
                           • Button has a simpler theme contract — explicit
                             Foreground=DynamicResource keeps the text
                             readable on both light and dark themes, and the
                             pressed/hover states are predictable. -->
                        <StackPanel IsVisible="{Binding HasProjectBreakdown}" Spacing="2">
                            <Button Command="{Binding ToggleProjectBreakdownCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0,4"
                                    HorizontalContentAlignment="Left"
                                    HorizontalAlignment="Stretch"
                                    Foreground="{DynamicResource AppPrimaryTextBrush}"
                                    Cursor="Hand"
                                    AutomationProperties.Name="{x:Static loc:Strings.HeaderProjectTranscriptBreakdown}"
                                    ToolTip.Tip="{x:Static loc:Strings.TipProjectTranscriptBreakdown}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="▶"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !IsProjectBreakdownExpanded}" />
                                    <TextBlock Text="▼"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsProjectBreakdownExpanded}" />
                                    <TextBlock Text="{x:Static loc:Strings.HeaderProjectTranscriptBreakdown}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <ItemsControl ItemsSource="{Binding ProjectTranscripts}"
                                          IsVisible="{Binding IsProjectBreakdownExpanded}"
                                          HorizontalAlignment="Stretch">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProjectTranscriptRowViewModel">
                                        <Border Padding="8,6"
                                                BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <DockPanel LastChildFill="True">
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <!-- The breakdown's ItemsControl inherits its DataContext
                                                     from the surrounding StackPanel/TabItem, which IS the
                                                     MemoryEditorViewModel.  Skip the row's local DataContext
                                                     (ProjectTranscriptRowViewModel) and reach back to the
                                                     ItemsControl's DataContext for command dispatch. -->
                                                    <Button Content="{x:Static loc:Strings.ButtonOpenInEditor}"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            AutomationProperties.Name="{Binding DisplayName, StringFormat='Open project {0} in editor'}"
                                                            Command="{Binding $parent[ItemsControl].((vm:MemoryEditorViewModel)DataContext).OpenInEditorCommand}"
                                                            CommandParameter="{Binding AbsolutePath}" />
                                                    <Button Content="{x:Static loc:PlatformLabels.Reveal}"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            AutomationProperties.Name="{Binding DisplayName, StringFormat='Reveal project {0} in file manager'}"
                                                            Command="{Binding $parent[ItemsControl].((vm:MemoryEditorViewModel)DataContext).RevealCommand}"
                                                            CommandParameter="{Binding AbsolutePath}" />
                                                    <Button Content="{x:Static loc:Strings.ButtonDeleteFootprint}"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            Foreground="#C62828"
                                                            AutomationProperties.Name="{Binding DisplayName, StringFormat='Delete transcripts for project {0}'}"
                                                            Command="{Binding $parent[ItemsControl].((vm:MemoryEditorViewModel)DataContext).DeleteProjectTranscriptsCommand}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                                <Grid ColumnDefinitions="*,80,80,140" RowDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               ToolTip.Tip="{Binding MangledName}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                                               Text="{Binding AbsolutePath}"
                                                               Opacity="0.6"
                                                               FontSize="11"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontFamily="Consolas, Menlo, monospace" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                                               Text="{Binding FileCount}"
                                                               Opacity="0.8"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                                                               Text="{Binding HumanSize}"
                                                               Opacity="0.8"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                    <StackPanel Grid.Row="0" Grid.Column="3" Grid.RowSpan="2"
                                                                Orientation="Horizontal" Spacing="4"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock
                                                            Text="{x:Static loc:Strings.HeaderProjectColumnLastSeen}"
                                                            FontSize="11" Opacity="0.7" />
                                                        <TextBlock Text="{Binding LastWriteDisplay}"
                                                                   FontSize="11" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Grid>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- Desktop section — explainer panel, no Tier 1/2 surface. -->
            <Border Background="{DynamicResource NavSelectedAccentBrush}"
                    TextElement.Foreground="White"
                    CornerRadius="6"
                    Padding="14,8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0">
                <TextBlock Text="{x:Static loc:Strings.HeaderMemoryDesktop}"
                           FontWeight="SemiBold" FontSize="14" />
            </Border>
            <Border BorderBrush="{DynamicResource AppPanelBorderBrush}"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="4">
                <StackPanel Spacing="6">
                    <TextBlock Text="{x:Static loc:Strings.LabelDesktopMemoryExplainerTitle}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{x:Static loc:Strings.LabelDesktopMemoryExplainerBody}"
                               TextWrapping="Wrap"
                               Opacity="0.85" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
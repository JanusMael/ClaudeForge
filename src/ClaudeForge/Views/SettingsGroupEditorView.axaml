<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bennewitz.Ninja.ClaudeForge.ViewModels"
             xmlns:libvm="using:Bennewitz.Ninja.LayeredEditors.Avalonia.ViewModels"
             xmlns:controls="using:Bennewitz.Ninja.ClaudeForge.Controls"
             xmlns:lecontrols="using:Bennewitz.Ninja.LayeredEditors.Avalonia.Controls"
             xmlns:conv="using:Bennewitz.Ninja.ClaudeForge.Converters"
             xmlns:core="using:Bennewitz.Ninja.ClaudeForge.Core.Settings"
             xmlns:loc="clr-namespace:Bennewitz.Ninja.ClaudeForge.Localization"
             xmlns:leconv="using:Bennewitz.Ninja.LayeredEditors.Avalonia.Converters"
             xmlns:views="using:Bennewitz.Ninja.ClaudeForge.Views"
             x:Class="Bennewitz.Ninja.ClaudeForge.Views.SettingsGroupEditorView"
             x:DataType="vm:SettingsGroupEditorViewModel">

    <UserControl.Resources>
        <conv:ScopeToBrushConverter x:Key="ScopeToBrush" />
        <conv:ScopeToDisplayNameConverter x:Key="ScopeToName" />
        <conv:ScopeToTooltipConverter x:Key="ScopeToTooltip" />
        <leconv:SuppressNullWriteConverter x:Key="SuppressNullWrite" />

        <!--
            Colored-chiclet item template for the Editing scope ComboBox.
            Each scope renders as a small filled pill (badge background from
            ScopeToBrush, white name text from ScopeToName) so the user reads
            scope identity by COLOR, not by parsing the lowercase enum text.
            Reused for both ItemTemplate (open dropdown rows) and
            SelectionBoxItemTemplate (closed-pill selected display).
        -->
        <DataTemplate x:Key="ScopeChicletTemplate" x:DataType="core:ConfigScope">
            <Border Background="{Binding ., Converter={StaticResource ScopeToBrush}}"
                    CornerRadius="4" Padding="8,2"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    ToolTip.Tip="{Binding ., Converter={StaticResource ScopeToTooltip}}">
                <TextBlock Text="{Binding ., Converter={StaticResource ScopeToName}}"
                           Foreground="White" FontWeight="Bold" FontSize="11" />
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>

        <!-- Header: group name + scope selector -->
        <Border DockPanel.Dock="Top"
                Padding="16,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <!--
                        Active editing-context summary.

                        Shows the same icon + summary text the persistent
                        status row used to display ("📁 project: foo" or
                        "🏠 User config — no project open"), but inline next
                        to the Editing-scope dropdown so it lives where the
                        scope decision is made. Bound to the Window's
                        DataContext (MainWindowViewModel) — the editor's own
                        DataContext is SettingsGroupEditorViewModel, which
                        does not carry the project-state properties.
                    -->
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditingContextSummary}">
                        <TextBlock
                            Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditingContextIcon}"
                            FontSize="12" VerticalAlignment="Center" />
                        <TextBlock
                            Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditingContextSummary}"
                            FontSize="11"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            MaxWidth="280"
                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>

                    <!-- Visual divider between active-scope summary and the editing-scope picker -->
                    <Border Width="1" Margin="2,4"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

                    <TextBlock Text="{x:Static loc:Strings.LabelEditingScope}" VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               ToolTip.Tip="{x:Static loc:Strings.TipEditingScopeLabel}" />
                    <!--
                        BINDING NOTE — cross-product scope bleed:
                        Avalonia's ContentControl reuses the same SettingsGroupEditorView
                        instance when navigating between two SettingsGroupEditorViewModel
                        pages (same DataTemplate type).  During a DataContext switch the
                        ItemsSource and SelectedItem bindings are NOT updated atomically:
                        ItemsSource may change from [User, Project, Local] → [User] while
                        the ComboBox SelectedItem is still "Local" from the previous page.
                        The ComboBox then clears its selection, and the default TwoWay
                        binding pushes the stale/cleared value back to the incoming VM's
                        EditingScope — contaminating a Claude Desktop VM with a "Local"
                        scope that its workspace doesn't support.

                        Two defences cooperate here:

                        1. SuppressNullWriteConverter on the SelectedItem binding drops
                           the transient `null` write that happens when SelectionModel
                           clears an out-of-range selection during the DataContext swap.
                           Without this converter the null → ConfigScope coercion fails
                           deep inside Avalonia (BindingExpression.WriteValueToSource →
                           OnDataValidationError) and raises an InvalidCastException that
                           bypasses the setter entirely, so the VM-side guard below never
                           runs.

                        2. SettingsGroupEditorViewModel.OnEditingScopeChanged defends
                           against stale-but-valid writes: if some other code path pushes
                           a ConfigScope that is in one workspace's AvailableScopes but
                           not this VM's, it snaps EditingScope back to the shared
                           context's current valid value.  See that method for details.
                    -->
                    <ComboBox ItemsSource="{Binding AvailableScopes}"
                              SelectedItem="{Binding EditingScope, Converter={StaticResource SuppressNullWrite}}"
                              ItemTemplate="{StaticResource ScopeChicletTemplate}"
                              SelectionBoxItemTemplate="{StaticResource ScopeChicletTemplate}"
                              MinWidth="100"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              ToolTip.Tip="{x:Static loc:Strings.TipEditingScopeCombo}"
                              AutomationProperties.Name="{x:Static loc:Strings.AutoNameEditingScope}"
                              AutomationProperties.HelpText="{x:Static loc:Strings.AutoHelpEditingScope}" />
                    <!--
                        Per-editor "?" scope explainer.

                        Sits next to the scope ComboBox so that a user who is
                        ABOUT to write to a scope can quickly remind themselves
                        what that scope means without leaving the editor or
                        navigating back to the Welcome page. Click toggles a
                        light-dismissable Popup containing the same ScopeLegend
                        control used on Welcome and the Backup/Restore page.
                    -->
                    <Button Name="ScopeLegendButton"
                            Content="?"
                            FontSize="11"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{x:Static loc:Strings.TipScopeLegendButton}"
                            AutomationProperties.Name="{x:Static loc:Strings.TipScopeLegendButton}"
                            Click="OnScopeLegendButtonClick" />
                    <Popup Name="ScopeLegendPopup"
                           PlacementTarget="{Binding #ScopeLegendButton}"
                           Placement="BottomEdgeAlignedRight"
                           IsLightDismissEnabled="True">
                        <Border Background="{DynamicResource SearchPopupBackgroundBrush}"
                                BorderBrush="{DynamicResource SearchPopupBorderBrush}"
                                BorderThickness="1"
                                MaxWidth="640">
                            <controls:ScopeLegend />
                        </Border>
                    </Popup>
                    <!-- Inline write-error: shown when a workspace SetValue fails.
                         SelectableTextBlock lets the user Ctrl+A / Ctrl+C the error text. -->
                    <SelectableTextBlock
                        Text="{Binding EditorError}"
                        IsVisible="{Binding EditorError,
                                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                        FontSize="11"
                        TextWrapping="Wrap"
                        MaxWidth="400"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{x:Static loc:Strings.TipEditorErrorCopy}" />
                </StackPanel>
                <!--
                    Page heading + brief one-line description, presented in
                    a coloured pill that mirrors the navigation tree's
                    selected-item background. The intent is "what's
                    highlighted in the sidebar is also highlighted at the
                    top of the content area" so the user always sees a
                    clear visual link between the two.

                    The pill uses NavSelectedAccentBrush — defined in
                    MainWindow.axaml's theme dictionaries (light:
                    #FF1664F0, dark: #FF3375E0) and ALSO applied as the
                    TreeViewItem :selected background on the navigation
                    tree, so the two surfaces are guaranteed to share
                    exactly the same colour without depending on
                    Semi.Avalonia's internal brush keys (which vary
                    across versions and resolved to invisible-on-white
                    fills in 12.0.0).

                    TextElement.Foreground is set to White so both the
                    title (18pt SemiBold) and the description (11pt at
                    92% opacity) render legibly against the accent fill
                    in light AND dark themes — WCAG AA at the heading
                    size.
                -->
                <Border Background="{DynamicResource NavSelectedAccentBrush}"
                        TextElement.Foreground="White"
                        CornerRadius="6"
                        Padding="14,8"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Vertical" Spacing="0">
                        <TextBlock Text="{Binding GroupName}"
                                   FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding GroupDescription}"
                                   IsVisible="{Binding GroupDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="600"
                                   Opacity="0.92"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Data-driven tab strip. Items come from SettingsGroupEditorViewModel.Tabs
             (built-ins Properties/Effective/JSON, seeded by RebuildTabs, plus any
             contributed tabs an IGroupTabCustomizer inserted — e.g. the Permissions
             group's Common/Build/Lists/Advanced). The header is GroupTab.Header; the
             body is chosen by GroupTabBodyTemplate keyed on GroupTab.Id, with the
             body's DataContext set to GroupTab.Content. SelectedItem is two-way
             bound so the choice is remembered across rebuilds / navigation; the
             VM seeds it from the remembered tab → customizer default → first. -->
        <TabControl ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}">
            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="vm:GroupTab">
                    <TextBlock Text="{Binding Header}"
                               AutomationProperties.Name="{Binding AutomationName}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <views:GroupTabBodyTemplate />
            </TabControl.ContentTemplate>
        </TabControl>

    </DockPanel>
</UserControl>
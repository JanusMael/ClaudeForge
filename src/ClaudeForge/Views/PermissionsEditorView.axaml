<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bennewitz.Ninja.ClaudeForge.ViewModels.Editors"
             xmlns:loc="clr-namespace:Bennewitz.Ninja.ClaudeForge.Localization"
             xmlns:perm="using:Bennewitz.Ninja.ClaudeForge.Avalonia.Permissions"
             xmlns:views="using:Bennewitz.Ninja.ClaudeForge.Views"
             x:Class="Bennewitz.Ninja.ClaudeForge.Views.PermissionsEditorView"
             x:DataType="vm:PermissionsEditorViewModel">

    <!--
        Permissions "Overview" body. The heavy activity surfaces (Common presets,
        guided Build, rule Lists) are top-level sibling tabs contributed by
        ClaudeGroupTabCustomizer + rendered by GroupTabBodyTemplate. This control
        is what the built-in (relabeled "Overview") tab shows: the rule-syntax
        explainer, the inline "How permission rules work" accordion, the Default
        Mode selector with its contextual warning banners, and an Advanced
        accordion (disableBypass + additionalDirectories) at the end.
    -->
    <StackPanel Spacing="12" Margin="0,8">

        <!-- ═══════════════════════════════════════════════════════════
             Explainer + inline education accordion
             ═══════════════════════════════════════════════════════════ -->
        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12,8">
            <TextBlock Text="{x:Static loc:Strings.TextPermissionsExplainer}"
                       FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
        </Border>

        <!-- defaultMode — surfaced near the top so it's one of the first
             things the user sees. -->
        <StackPanel Spacing="4">
            <TextBlock Text="{x:Static loc:Strings.LabelDefaultMode}" FontWeight="SemiBold" />
            <TextBlock Text="{x:Static loc:Strings.TextDefaultModeHint}"
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <!-- ItemsSource = DefaultModeInfo list; SelectedItem = SelectedModeInfo (computed).
                 Row shows the raw camelCase value in monospace + the localized description.
                 ToolTip.Tip adds Claude's friendly wording (TooltipText = ClaudeLabel +
                 description); AutomationProperties.Name (AccessibleName) carries value +
                 friendly label + description for screen-reader announcement. -->
            <ComboBox ItemsSource="{Binding DefaultModeInfos}"
                      SelectedItem="{Binding SelectedModeInfo}"
                      PlaceholderText="{x:Static loc:Strings.PlaceholderDefaultMode}"
                      AutomationProperties.Name="{x:Static loc:Strings.LabelDefaultMode}"
                      MinWidth="300">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DefaultModeInfo">
                        <DockPanel ToolTip.Tip="{Binding TooltipText}"
                                   AutomationProperties.Name="{Binding AccessibleName}">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="{Binding Value}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       MinWidth="140" />
                            <TextBlock Text="{Binding Description}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       IsVisible="{Binding $parent[ComboBoxItem], Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Contextual hint: visible when user arrived via "danger*" search -->
            <Border IsVisible="{Binding ShowDangerCliHint}"
                    BorderBrush="#E65100"
                    BorderThickness="2"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="10,8"
                    Margin="0,2,0,2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="ℹ"
                               FontSize="15"
                               Foreground="#E65100"
                               VerticalAlignment="Top"
                               Margin="0,1,0,0" />
                    <TextBlock FontSize="11"
                               TextWrapping="Wrap"
                               MaxWidth="500"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppPrimaryTextBrush}">
                        <Run FontWeight="Bold" Foreground="#E65100" FontFamily="Consolas,Menlo,monospace">--dangerouslySkipPermissions</Run>
                        <Run Text=" has no direct config-file key. Selecting " />
                        <Run FontWeight="Bold" Foreground="#E65100" FontFamily="Consolas,Menlo,monospace">bypassPermissions</Run>
                        <Run Text=" in the dropdown below has the same effect — it skips all permission prompts." />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Contextual hint: visible when user arrived via "bypass" search -->
            <Border IsVisible="{Binding ShowSelectBypassHint}"
                    BorderBrush="#E65100"
                    BorderThickness="2"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="10,8"
                    Margin="0,2,0,2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="ℹ"
                               FontSize="15"
                               Foreground="#E65100"
                               VerticalAlignment="Top"
                               Margin="0,1,0,0" />
                    <TextBlock Text="{x:Static loc:Strings.TextSelectBypassHint}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               MaxWidth="500"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppPrimaryTextBrush}" />
                </StackPanel>
            </Border>

            <!-- Auto-mode advisory: shown when an ineligible 'auto' selection was
                 coerced away (model not auto-capable, or scope not User). -->
            <Border IsVisible="{Binding ShowAutoModeWarning}"
                    BorderBrush="{DynamicResource AppCautionBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,5"
                    Margin="0,2,0,2">
                <TextBlock Text="{x:Static loc:Strings.LabelAutoModeCoerced}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           Foreground="{DynamicResource AppPrimaryTextBrush}" />
            </Border>

            <!-- Danger banner: visible only when bypassPermissions is selected -->
            <Border IsVisible="{Binding IsInBypassMode}"
                    BorderBrush="#C62828"
                    BorderThickness="2"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="12,10"
                    Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="⚠"
                               FontSize="20"
                               Foreground="#C62828"
                               VerticalAlignment="Top"
                               Margin="0,1,0,0" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static loc:Strings.LabelEquivalentToBypass}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="#C62828" />
                        <TextBlock Text="{x:Static loc:Strings.TextBypassPermissionsWarning}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"
                                   MaxWidth="520" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- "How permission rules work" — accordion placed after Default Mode and
             before Advanced. Self-contained Expander; rich inline formatting
             (monospace + accent for code tokens) is applied in its code-behind. -->
        <perm:PermissionRuleEducationPanel />

        <!-- Advanced (disableBypass + additionalDirectories) as a collapsed
             accordion at the end of the Overview, rather than its own tab.
             Reuses the extracted PermissionsAdvancedView; DataContext inherits
             this control's PermissionsEditorViewModel. -->
        <Expander Header="{x:Static loc:Strings.TabPermAdvanced}"
                  IsExpanded="{Binding IsAdvancedExpanded}">
            <views:PermissionsAdvancedView Margin="0,4,0,0" />
        </Expander>
    </StackPanel>
</UserControl>

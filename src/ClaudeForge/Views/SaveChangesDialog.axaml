<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Bennewitz.Ninja.ClaudeForge.ViewModels"
        xmlns:conv="using:Bennewitz.Ninja.ClaudeForge.Converters"
        xmlns:app="using:Bennewitz.Ninja.ClaudeForge"
        xmlns:loc="clr-namespace:Bennewitz.Ninja.ClaudeForge.Localization"
        x:Class="Bennewitz.Ninja.ClaudeForge.Views.SaveChangesDialog"
        x:DataType="vm:SaveChangesDialogViewModel"
        Title="{Binding WindowTitle}"
        Width="800"
        MinWidth="560"
        MinHeight="420"
        MaxHeight="700"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Window.Resources>
        <conv:ScopeToBrushConverter x:Key="ScopeToBrush" />
        <conv:ScopeToDisplayNameConverter x:Key="ScopeToName" />
        <!-- Used by Old/New value TipCells to pretty-print JSON blobs as hover tooltips.
             Defined as a StaticResource rather than {x:Static} so compiled bindings
             resolve the converter correctly inside nested DataTemplates. -->
        <conv:LongValueTooltipConverter x:Key="LongValueTooltip" />
    </Window.Resources>

    <DockPanel>

        <!--
            Top-of-dialog summary line.
            Tells the user up-front how many individual changes they're about
            to commit and across how many distinct files. Phrasing varies by
            mode ("Saving N change(s) across M file(s)" vs "Restoring …").
        -->
        <Border DockPanel.Dock="Top"
                Padding="12,8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <!-- 2026-05-07: small AppIcon inline at the top of the dialog
                 alongside the summary line.  Wires up the previously-dead
                 AppIcon.SmallBitmapInstance (16×16 render of the
                 simplified ClaudeForge-small.svg) so users have a visual
                 cue that this dialog is the trusted ClaudeForge save
                 confirmation, not (e.g.) an OS prompt that landed on top
                 of it.  Uses a 16×16 logical box so the icon stays
                 proportional to the SummaryLine text height. -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Image Source="{x:Static app:AppIcon.SmallBitmapInstance}"
                       Width="16" Height="16"
                       VerticalAlignment="Center" />
                <TextBlock Text="{Binding SummaryLine}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </Border>

        <!-- ── Bottom button bar ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Padding="12,8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <!-- I20: AutomationProperties.Name reuses the existing Content key
                     since the visible label is already the right screen-reader name. -->
                <CheckBox DockPanel.Dock="Left"
                          Content="{x:Static loc:Strings.CheckboxShowDialog}"
                          IsChecked="{Binding ShowDialogAgain}"
                          VerticalAlignment="Center"
                          ToolTip.Tip="{x:Static loc:Strings.TipCheckboxShowDialog}"
                          AutomationProperties.Name="{x:Static loc:Strings.CheckboxShowDialog}" />
                <Button DockPanel.Dock="Left"
                        Margin="12,0,0,0"
                        Content="{x:Static loc:Strings.ButtonCopyAllChanges}"
                        Click="OnCopyAll"
                        ToolTip.Tip="{x:Static loc:Strings.TipButtonCopyAllChanges}"
                        AutomationProperties.Name="{x:Static loc:Strings.ButtonCopyAllChanges}" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12">
                    <!-- AutomationProperties.Name binds to the same property as Content
                         so screen readers announce whatever the VM currently displays
                         (varies by mode: "Cancel" for Save flow, "Cancel restore" for
                         Restore flow). -->
                    <Button Content="{Binding CancelButtonLabel}"
                            IsCancel="True"
                            MinWidth="80"
                            Click="OnCancel"
                            AutomationProperties.Name="{Binding CancelButtonLabel}" />
                    <Button Content="{Binding ConfirmButtonLabel}"
                            IsDefault="True"
                            MinWidth="80"
                            Click="OnSave"
                            AutomationProperties.Name="{Binding ConfirmButtonLabel}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Change list ─────────────────────────────────────────────────── -->
        <!-- DataGrid is NOT used here deliberately.  Inside a SizeToContent="Height"
             Window, any ScrollViewer always passes ∞ downward to its content regardless
             of the ScrollViewer's own MaxHeight.  Avalonia's DataGridRowsPresenter
             resolves CellsHeight to 0 when its available height is ∞, so rows are never
             materialised on first paint — they only appear after an external resize forces
             a second arrange with a real finite height.  An ItemsControl + Grid rows has
             no such virtualisation, so all rows render correctly on first paint.
             MaxHeight keeps the ScrollViewer (and therefore the dialog) within the
             Window's MaxHeight="700" ceiling even when many changes are pending. -->
        <ScrollViewer Padding="12,8,12,4"
                      MaxHeight="640">
            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SaveChangeSectionViewModel">
                        <StackPanel Margin="0,0,0,16" Spacing="6">

                            <!-- Section header (coloured by scope) -->
                            <Border Background="{Binding Scope, Converter={StaticResource ScopeToBrush}}"
                                    CornerRadius="4" Padding="10,4">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="White" />
                            </Border>

                            <!--
                                Destination path row.

                                Sits directly below the coloured workspace+scope chip so the
                                user has a clear "this change goes to THIS file" line of sight
                                before clicking Save / Restore. Path is rendered in monospace
                                with `~/...` shorthand for paths under the user profile (see
                                MainWindowViewModel.ToDisplayPath). Selectable so the user can
                                Ctrl+C the path if they want to inspect the file directly.
                            -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        Margin="2,0,0,0"
                                        IsVisible="{Binding FilePath,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding ActionVerb}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <SelectableTextBlock Text="{Binding FilePath}"
                                                     FontFamily="Consolas,Menlo,monospace"
                                                     FontSize="11"
                                                     VerticalAlignment="Center"
                                                     ToolTip.Tip="{Binding FilePath}" />
                            </StackPanel>

                            <!-- Per-property changes as a lightweight Grid-row table.
                                 Column definitions are identical in the header Grid and every
                                 data-row Grid; since all Grids share the same available width
                                 from their StackPanel parent, star columns compute to the same
                                 pixel widths and columns stay visually aligned. -->
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,4,0,0">
                                <StackPanel>

                                    <!-- Header row -->
                                    <Grid ColumnDefinitions="28,2*,3*,3*"
                                          Margin="8,5,8,5">
                                        <TextBlock Grid.Column="0" Text=""
                                                   FontSize="11" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Static loc:Strings.HeaderSaveDialogProperty}"
                                                   FontSize="11" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" Text="{x:Static loc:Strings.HeaderSaveDialogOld}"
                                                   FontSize="11" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="3" Text="{x:Static loc:Strings.HeaderSaveDialogNew}"
                                                   FontSize="11" FontWeight="SemiBold" />
                                    </Grid>

                                    <Separator Margin="0" />

                                    <!-- Data rows (non-virtualising — no ∞-height issue) -->
                                    <ItemsControl ItemsSource="{Binding Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SaveChangeEntryViewModel">
                                                <Grid ColumnDefinitions="28,2*,3*,3*"
                                                      Margin="8,4,8,4">
                                                    <!-- Coloured kind pill: green '+' for added, red '-' for removed,
                                                         orange '~' for modified.  ToolTip + AutomationProperties.Name
                                                         bind to KindAccessibleName so the bare glyph isn't the only
                                                         signal of the change type — sighted users get a hover tooltip
                                                         and screen-reader users get a real word announced.  Per the
                                                         2026-05-15 a11y sweep, displays should never depend solely on
                                                         colour or a single-glyph cue. -->
                                                    <Border Grid.Column="0"
                                                            Background="{Binding KindBackground}"
                                                            CornerRadius="3"
                                                            Padding="4,1"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            ToolTip.Tip="{Binding KindAccessibleName}"
                                                            AutomationProperties.Name="{Binding KindAccessibleName}">
                                                        <TextBlock Text="{Binding KindLabel}"
                                                                   Foreground="White"
                                                                   FontFamily="Consolas,Menlo,monospace"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Key}"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center" />
                                                    <!-- Old-value cell.
                                                         SelectableTextBlock gives the user mouse-drag selection
                                                         and Ctrl+C on the displayed (truncated) text natively.
                                                         The single "Copy" context-menu item copies the
                                                         UNTRUNCATED FullOldValue — that's what users want when
                                                         they right-click a JSON cell, since the displayed text
                                                         is capped at 80 chars by SaveDialogBuilder.TruncateJson.
                                                         ToolTip.Tip is on the TextBlock itself so hovering the
                                                         text (not just the cell gap) shows the full value. -->
                                                    <Border Grid.Column="2"
                                                            Background="Transparent"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch">
                                                        <SelectableTextBlock Text="{Binding OldValue}"
                                                                             TextWrapping="Wrap"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                             ToolTip.Tip="{Binding FullOldValue,
                                                                                 Converter={StaticResource LongValueTooltip}}">
                                                            <SelectableTextBlock.ContextFlyout>
                                                                <MenuFlyout>
                                                                    <MenuItem
                                                                        Header="{x:Static loc:Strings.LabelMenuCopy}"
                                                                        Tag="FullOld"
                                                                        Click="OnCopyCellValue" />
                                                                </MenuFlyout>
                                                            </SelectableTextBlock.ContextFlyout>
                                                        </SelectableTextBlock>
                                                    </Border>
                                                    <!-- New-value cell — same pattern as Old. -->
                                                    <Border Grid.Column="3"
                                                            Background="Transparent"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch">
                                                        <SelectableTextBlock Text="{Binding NewValue}"
                                                                             TextWrapping="Wrap"
                                                                             VerticalAlignment="Center"
                                                                             ToolTip.Tip="{Binding FullNewValue,
                                                                                 Converter={StaticResource LongValueTooltip}}">
                                                            <SelectableTextBlock.ContextFlyout>
                                                                <MenuFlyout>
                                                                    <MenuItem
                                                                        Header="{x:Static loc:Strings.LabelMenuCopy}"
                                                                        Tag="FullNew"
                                                                        Click="OnCopyCellValue" />
                                                                </MenuFlyout>
                                                            </SelectableTextBlock.ContextFlyout>
                                                        </SelectableTextBlock>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
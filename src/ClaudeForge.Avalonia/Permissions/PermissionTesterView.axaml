<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Bennewitz.Ninja.ClaudeForge.Avalonia.Permissions"
             xmlns:conv="clr-namespace:Bennewitz.Ninja.ClaudeForge.Avalonia.Converters"
             xmlns:loc="clr-namespace:Bennewitz.Ninja.ClaudeForge.Avalonia.Localization"
             x:Class="Bennewitz.Ninja.ClaudeForge.Avalonia.Permissions.PermissionTesterView"
             x:DataType="vm:PermissionTesterViewModel">

    <!--
        Dry-run tester. The user describes a candidate action; the verdict
        (Allow/Ask/Deny/Default) updates live, colored by outcome, with a
        plain-English explanation naming the matched rule/bucket/scope. The
        merged toggle switches between the editing scope and the merged view.
    -->
    <StackPanel Spacing="10">
        <TextBlock Text="{x:Static loc:Strings.PermTesterHeading}"
                   FontWeight="SemiBold" FontSize="14"
                   AutomationProperties.HeadingLevel="2" />

        <StackPanel Spacing="4">
            <TextBlock Text="{x:Static loc:Strings.PermTesterToolLabel}" />
            <ComboBox ItemsSource="{Binding AvailableTools}"
                      SelectedItem="{Binding SelectedTool}"
                      MinWidth="160"
                      AutomationProperties.Name="{x:Static loc:Strings.PermTesterToolLabel}" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowCommandInput}">
            <TextBlock Text="{x:Static loc:Strings.PermTesterCommandLabel}" />
            <TextBox Text="{Binding CommandText}"
                     ToolTip.Tip="{x:Static loc:Strings.PermTesterInputTip}"
                     AutomationProperties.Name="{x:Static loc:Strings.PermTesterCommandLabel}" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowPathInput}">
            <TextBlock Text="{x:Static loc:Strings.PermTesterPathLabel}" />
            <TextBox Text="{Binding PathText}"
                     ToolTip.Tip="{x:Static loc:Strings.PermTesterInputTip}"
                     AutomationProperties.Name="{x:Static loc:Strings.PermTesterPathLabel}" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowUrlInput}">
            <TextBlock Text="{x:Static loc:Strings.PermTesterUrlLabel}" />
            <TextBox Text="{Binding Url}"
                     ToolTip.Tip="{x:Static loc:Strings.PermTesterInputTip}"
                     AutomationProperties.Name="{x:Static loc:Strings.PermTesterUrlLabel}" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowMcpInput}">
            <TextBlock Text="{x:Static loc:Strings.PermTesterMcpServerLabel}" />
            <TextBox Text="{Binding McpServer}"
                     AutomationProperties.Name="{x:Static loc:Strings.PermTesterMcpServerLabel}" />
            <TextBox Text="{Binding McpTool}"
                     PlaceholderText="{x:Static loc:Strings.PermTesterMcpToolLabel}"
                     AutomationProperties.Name="{x:Static loc:Strings.PermTesterMcpToolLabel}" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowAgentInput}">
            <TextBlock Text="{x:Static loc:Strings.PermTesterAgentLabel}" />
            <TextBox Text="{Binding AgentName}"
                     AutomationProperties.Name="{x:Static loc:Strings.PermTesterAgentLabel}" />
        </StackPanel>

        <CheckBox IsChecked="{Binding UseMergedView}"
                  Content="{x:Static loc:Strings.PermTesterMergedLabel}"
                  ToolTip.Tip="{x:Static loc:Strings.PermTesterMergedTip}"
                  AutomationProperties.Name="{x:Static loc:Strings.PermTesterMergedLabel}" />

        <!-- Empty state: no concrete candidate yet (e.g. a bare-tool rule with no
             path/command was sent here). Tells the user a value is needed rather
             than showing a blank pane. -->
        <TextBlock Text="{x:Static loc:Strings.PermTesterNoInput}"
                   IsVisible="{Binding !HasResult}"
                   FontSize="12" FontStyle="Italic" Opacity="0.8"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{x:Static loc:Strings.PermTesterNoInput}" />

        <!-- Verdict -->
        <Border IsVisible="{Binding HasResult}"
                Background="{DynamicResource AppCodeBlockBackgroundBrush}"
                BorderBrush="{DynamicResource AppPanelBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10,8">
            <StackPanel Spacing="6">
                <!-- Result: <label> <Outcome> on one row -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Static loc:Strings.PermTesterResultHeading}"
                               FontSize="13" Opacity="0.8"
                               VerticalAlignment="Center"
                               AutomationProperties.HeadingLevel="3" />
                    <TextBlock Text="{Binding OutcomeLabel}"
                               FontWeight="Bold" FontSize="16"
                               Foreground="{Binding Outcome, Converter={x:Static conv:PermissionOutcomeToBrushConverter.Instance}}"
                               AutomationProperties.Name="{Binding OutcomeLabel}" />
                </StackPanel>
                <!-- Dedicated Scope callout — always shown, rendered with the same
                     colored scope chiclet used elsewhere in the app. -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding HasMatchedScope}">
                    <TextBlock Text="{x:Static loc:Strings.PermTesterScopeLabel}"
                               FontSize="13" Opacity="0.8" VerticalAlignment="Center" />
                    <Border CornerRadius="4" Padding="7,1" VerticalAlignment="Center"
                            Background="{Binding MatchedScope, Converter={x:Static conv:ConfigScopeToBrushConverter.Instance}}"
                            ToolTip.Tip="{Binding MatchedScope, Converter={x:Static conv:ConfigScopeToTooltipConverter.Instance}}">
                        <TextBlock Text="{Binding MatchedScopeLabel}"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="White"
                                   AutomationProperties.Name="{Binding MatchedScopeLabel}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding Explanation}"
                           TextWrapping="Wrap" FontSize="12"
                           AutomationProperties.Name="{Binding Explanation}" />
                <TextBlock Text="{Binding ReadOnlyNote}"
                           IsVisible="{Binding ReadOnlyNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           TextWrapping="Wrap" FontSize="11" Opacity="0.85"
                           AutomationProperties.Name="{Binding ReadOnlyNote}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
